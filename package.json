{
  "name": "intellmeet",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.8",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=18"
  }
}
