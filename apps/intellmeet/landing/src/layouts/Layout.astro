---
import "../styles/global.css";

import GridBackground from "../components/background/GridBackground.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />

		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0"
		/>

		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>

		<title>IntellMeet</title>
	</head>

	<body
		class="
			bg-background
			text-foreground
			overflow-x-hidden
			antialiased
		"
	>
		<GridBackground />

		<main class="relative z-10">
			<slot />
		</main>
	</body>
</html>