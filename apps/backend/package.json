{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "IntellMeet backend service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "axios": "1.15.2",
    "bcrypt": "6.0.0",
    "cloudinary": "2.10.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.4.1",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.0",
    "morgan": "1.10.1",
    "multer": "2.1.1",
    "socket.io": "4.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.6.0",
    "tsx": "4.21.0"
  }
