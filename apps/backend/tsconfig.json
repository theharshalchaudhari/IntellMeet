{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",
    "ignoreDeprecations": "6.0",

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["*"],
      "@/controllers/*": ["controllers/*"],
      "@/services/*": ["services/*"],
      "@/utils/*": ["utils/*"],
      "@/config/*": ["config/*"],
      "@/middleware/*": ["middleware/*"]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "types": ["node", "vite/client"]
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}